{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flomo-transcriber",
  "version": "0.1.0",
  "identifier": "com.flomotranscriber.gui",
  "build": {
    "beforeDevCommand": "cmd /c npm run dev",
    "beforeBuildCommand": "cmd /c npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "flomo-transcriber",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
