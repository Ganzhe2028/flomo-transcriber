# LM Studio vision provider for Stage 2.
FLOMO_VLM_BASE_URL=http://127.0.0.1:1234/v1
FLOMO_VLM_MODEL=your-local-vision-model
FLOMO_VLM_TIMEOUT_SECONDS=180
# FLOMO_VLM_API_KEY=

# LM Studio text provider for optional Stage 5 local report generation.
FLOMO_LLM_BASE_URL=http://127.0.0.1:1234/v1
FLOMO_LLM_MODEL=your-local-text-model
FLOMO_LLM_TIMEOUT_SECONDS=120
# FLOMO_LLM_API_KEY=
